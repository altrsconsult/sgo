# .env.example — Variáveis do Chassi SGO
# Copie para .env e preencha. Não commite .env.
#
# Uso: Docker Compose (dev/prod) ou Node single-process.
# Para Portainer (stacks): use stack-env.example.txt na raiz.

# --- Obrigatórias em produção ---

# Secret para JWTs (string longa e aleatória em produção)
JWT_SECRET=changeme_very_long_secret_for_production

# Senha do PostgreSQL (Compose ou stack)
POSTGRES_PASSWORD=changeme_secure_password

# --- Banco de dados ---
# Compose usa POSTGRES_*; Node/Hostinger usa DATABASE_URL.
# DATABASE_URL=postgresql://sgo:senha@localhost:5432/sgo
# DATABASE_URL=mysql://sgo:senha@localhost:3306/sgo

# --- Admin inicial (instalação limpa: backend cria este usuário na primeira subida) ---
SGO_ADMIN_USERNAME=admin
SGO_ADMIN_PASSWORD=changeme_senha_forte_admin
# SGO_ADMIN_EMAIL=admin@empresa.com
# SGO_ADMIN_NAME=Administrador

# --- Opcionais ---
POSTGRES_DB=sgo
POSTGRES_USER=sgo

# Nexus (vazio = standalone)
# NEXUS_URL=https://nexus.seudominio.com.br

# URL pública do chassi (links, e-mails)
# CHASSIS_URL=https://sgo.seudominio.com.br

# Node single-process (Hostinger etc.): backend serve frontend estático
# SERVE_STATIC=true
# STATIC_PATH=./public
# PORT=3000
